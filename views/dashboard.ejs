<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vinnie Host | Modern Cloud Dashboard</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <style>
        :root {
            --bg: #050816;
            --bg2: #0b1020;
            --card: rgba(255, 255, 255, 0.06);
            --card2: rgba(255, 255, 255, 0.09);
            --border: rgba(255, 255, 255, 0.12);
            --muted: #94a3b8;
            --text: #f8fafc;
            --accent: #7c3aed;
            --accent2: #06b6d4;
            --success: #22c55e;
            --warning: #f59e0b;
            --danger: #ef4444;
            --dark: #020617;
        }

        * {
            box-sizing: border-box;
            scroll-behavior: smooth;
        }

        ::-webkit-scrollbar {
            width: 7px;
            height: 7px;
        }

        ::-webkit-scrollbar-track {
            background: rgba(255,255,255,0.04);
        }

        ::-webkit-scrollbar-thumb {
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            border-radius: 999px;
        }

        body {
            margin: 0;
            font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            background:
                radial-gradient(circle at top left, rgba(124, 58, 237, 0.25), transparent 30%),
                radial-gradient(circle at top right, rgba(6, 182, 212, 0.20), transparent 32%),
                linear-gradient(180deg, var(--bg), var(--bg2));
            color: var(--text);
            min-height: 100vh;
            overflow-x: hidden;
        }

        a {
            color: inherit;
            text-decoration: none;
        }

        .glass {
            background: var(--card);
            border: 1px solid var(--border);
            backdrop-filter: blur(18px);
            box-shadow: 0 20px 60px rgba(0,0,0,0.25);
        }

        .top-nav {
            position: sticky;
            top: 0;
            z-index: 1000;
            padding: 14px 5%;
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(5, 8, 22, 0.82);
            border-bottom: 1px solid var(--border);
            backdrop-filter: blur(18px);
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: 900;
            letter-spacing: -0.04em;
            font-size: 1.25rem;
        }

        .brand-icon {
            width: 42px;
            height: 42px;
            display: grid;
            place-items: center;
            border-radius: 14px;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            box-shadow: 0 0 30px rgba(124, 58, 237, 0.45);
        }

        .nav-links {
            display: flex;
            gap: 6px;
            align-items: center;
            overflow-x: auto;
            max-width: 58%;
            padding: 4px;
        }

        .nav-links a {
            padding: 9px 12px;
            border-radius: 999px;
            color: var(--muted);
            font-size: 0.83rem;
            white-space: nowrap;
            transition: 0.25s;
        }

        .nav-links a:hover {
            color: white;
            background: rgba(255,255,255,0.08);
        }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .slot-pill {
            border: 1px solid rgba(6, 182, 212, 0.35);
            background: rgba(6, 182, 212, 0.10);
            color: #67e8f9;
            padding: 8px 13px;
            border-radius: 999px;
            font-weight: 800;
            font-size: 0.8rem;
            white-space: nowrap;
        }

        .avatar {
            width: 40px;
            height: 40px;
            border-radius: 999px;
            border: 2px solid var(--accent2);
        }

        .mobile-menu-btn {
            display: none;
            border: 1px solid var(--border);
            background: var(--card);
            color: white;
            padding: 10px 12px;
            border-radius: 12px;
        }

        .mobile-menu {
            display: none;
            padding: 14px 5%;
            background: rgba(5, 8, 22, 0.95);
            border-bottom: 1px solid var(--border);
        }

        .mobile-menu a {
            display: block;
            padding: 12px;
            border-radius: 12px;
            color: var(--muted);
        }

        .mobile-menu a:hover {
            background: rgba(255,255,255,0.08);
            color: white;
        }

        .container {
            width: min(1200px, 92%);
            margin: 0 auto;
        }

        .hero {
            padding: 74px 0 44px;
            display: grid;
            grid-template-columns: 1.15fr 0.85fr;
            gap: 28px;
            align-items: center;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            border: 1px solid rgba(124, 58, 237, 0.35);
            background: rgba(124, 58, 237, 0.12);
            color: #ddd6fe;
            padding: 8px 13px;
            border-radius: 999px;
            font-size: 0.82rem;
            font-weight: 800;
        }

        .hero h1 {
            font-size: clamp(2.6rem, 6vw, 5.8rem);
            line-height: 0.92;
            letter-spacing: -0.08em;
            margin: 18px 0;
        }

        .gradient-text {
            background: linear-gradient(135deg, #fff, #a78bfa, #67e8f9);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero p {
            color: var(--muted);
            font-size: 1.05rem;
            line-height: 1.7;
            max-width: 680px;
        }

        .hero-actions {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-top: 26px;
        }

        .btn {
            border: none;
            cursor: pointer;
            border-radius: 14px;
            padding: 13px 18px;
            font-weight: 900;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 9px;
            transition: 0.25s;
        }

        .btn:hover {
            transform: translateY(-2px);
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            color: white;
            box-shadow: 0 18px 40px rgba(124, 58, 237, 0.28);
        }

        .btn-secondary {
            background: rgba(255,255,255,0.08);
            border: 1px solid var(--border);
            color: white;
        }

        .btn-success {
            background: linear-gradient(135deg, #16a34a, #22c55e);
            color: white;
        }

        .btn-danger {
            background: rgba(239, 68, 68, 0.12);
            color: #fecaca;
            border: 1px solid rgba(239, 68, 68, 0.35);
        }

        .hero-panel {
            padding: 24px;
            border-radius: 28px;
            position: relative;
            overflow: hidden;
        }

        .hero-panel::before {
            content: "";
            position: absolute;
            inset: -40%;
            background: conic-gradient(from 180deg, transparent, rgba(124, 58, 237, 0.3), rgba(6, 182, 212, 0.25), transparent);
            animation: spin 8s linear infinite;
            opacity: 0.6;
        }

        .hero-panel-inner {
            position: relative;
            background: rgba(2, 6, 23, 0.82);
            border: 1px solid var(--border);
            border-radius: 22px;
            padding: 22px;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        .mini-terminal {
            background: #020617;
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 18px;
            overflow: hidden;
        }

        .terminal-top {
            display: flex;
            gap: 7px;
            padding: 12px;
            border-bottom: 1px solid var(--border);
            background: rgba(255,255,255,0.04);
        }

        .dot {
            width: 10px;
            height: 10px;
            border-radius: 999px;
        }

        .dot.red { background: #fb7185; }
        .dot.yellow { background: #facc15; }
        .dot.green { background: #4ade80; }

        .terminal-code {
            padding: 17px;
            color: #a7f3d0;
            font-family: Consolas, Monaco, monospace;
            font-size: 0.86rem;
            line-height: 1.7;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 14px;
            margin: 24px 0 36px;
        }

        .stat-card {
            padding: 18px;
            border-radius: 22px;
        }

        .stat-card h3 {
            margin: 0;
            font-size: 1.7rem;
        }

        .stat-card p {
            margin: 7px 0 0;
            color: var(--muted);
            font-size: 0.85rem;
        }

        .section {
            padding: 38px 0;
        }

        .section-title {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 16px;
            margin-bottom: 18px;
        }

        .section-title h2 {
            margin: 0;
            font-size: clamp(1.7rem, 4vw, 2.6rem);
            letter-spacing: -0.05em;
        }

        .section-title p {
            color: var(--muted);
            max-width: 560px;
            line-height: 1.6;
        }

        .dashboard-grid {
            display: grid;
            grid-template-columns: 1.1fr 0.9fr;
            gap: 22px;
        }

        .card {
            padding: 23px;
            border-radius: 26px;
        }

        .card h3 {
            margin-top: 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .input-group {
            margin-top: 14px;
        }

        label {
            display: block;
            color: #cbd5e1;
            font-size: 0.82rem;
            font-weight: 800;
            margin-bottom: 8px;
        }

        input, select, textarea {
            width: 100%;
            padding: 14px;
            border-radius: 14px;
            border: 1px solid var(--border);
            background: rgba(2, 6, 23, 0.72);
            color: white;
            outline: none;
            transition: 0.22s;
        }

        input:focus, select:focus, textarea:focus {
            border-color: rgba(6, 182, 212, 0.7);
            box-shadow: 0 0 0 4px rgba(6, 182, 212, 0.09);
        }

        .search-wrap {
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 10px;
            align-items: center;
        }

        .dynamic-area {
            margin-top: 20px;
            border-top: 1px solid var(--border);
            padding-top: 18px;
            display: none;
        }

        .name-gen {
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 10px;
            align-items: center;
            padding: 13px;
            background: rgba(255,255,255,0.05);
            border: 1px dashed rgba(255,255,255,0.16);
            border-radius: 18px;
        }

        .identity {
            color: #67e8f9;
            font-family: Consolas, monospace;
            font-weight: 900;
        }

        .toggle-box {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 14px;
            padding: 13px;
            margin-top: 13px;
            background: rgba(255,255,255,0.05);
            border-radius: 16px;
        }

        .toggle-box input {
            width: auto;
        }

        .env-row {
            display: grid;
            grid-template-columns: 0.85fr 1.15fr auto;
            gap: 10px;
            margin-top: 10px;
            align-items: center;
        }

        .env-row input {
            margin: 0;
        }

        .small-btn {
            padding: 12px 13px;
            border-radius: 12px;
            background: rgba(255,255,255,0.08);
            border: 1px solid var(--border);
            color: white;
            cursor: pointer;
        }

        .small-btn:hover {
            background: rgba(255,255,255,0.13);
        }

        .plan-grid {
            display: grid;
            grid-template-columns: repeat(5, minmax(160px, 1fr));
            gap: 14px;
        }

        .plan-card {
            padding: 18px;
            border-radius: 22px;
            position: relative;
            overflow: hidden;
        }

        .plan-card.featured {
            border-color: rgba(6, 182, 212, 0.5);
            box-shadow: 0 0 40px rgba(6, 182, 212, 0.12);
        }

        .plan-price {
            font-size: 1.7rem;
            font-weight: 950;
            margin: 8px 0;
        }

        .plan-card ul {
            padding-left: 18px;
            color: var(--muted);
            line-height: 1.8;
            font-size: 0.88rem;
        }

        .app-list {
            display: grid;
            gap: 12px;
        }

        .app-item {
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 12px;
            align-items: center;
            padding: 14px;
            border-radius: 18px;
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--border);
        }

        .app-name {
            font-weight: 900;
            word-break: break-word;
        }

        .app-url {
            color: #67e8f9;
            font-size: 0.82rem;
            word-break: break-all;
        }

        .status {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            color: #bbf7d0;
            background: rgba(34,197,94,0.11);
            border: 1px solid rgba(34,197,94,0.30);
            padding: 6px 10px;
            border-radius: 999px;
            font-size: 0.75rem;
            font-weight: 900;
        }

        .pulse {
            width: 8px;
            height: 8px;
            border-radius: 999px;
            background: var(--success);
            box-shadow: 0 0 0 rgba(34, 197, 94, 0.7);
            animation: pulse 1.4s infinite;
        }

        @keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.7); }
            70% { box-shadow: 0 0 0 10px rgba(34, 197, 94, 0); }
            100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0); }
        }

        .terminal-wrapper {
            margin-top: 22px;
        }

        .terminal {
            background: #020617;
            color: #d1fae5;
            padding: 18px;
            border-radius: 18px;
            font-family: Consolas, Monaco, "Courier New", monospace;
            font-size: 13px;
            height: 380px;
            overflow-y: auto;
            border: 1px solid rgba(34,197,94,0.25);
            white-space: pre-wrap;
            box-shadow: inset 0 0 40px rgba(34,197,94,0.04);
        }

        .feature-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 14px;
        }

        .feature-card {
            padding: 20px;
            border-radius: 22px;
        }

        .feature-card i {
            font-size: 1.35rem;
            color: #67e8f9;
        }

        .feature-card p {
            color: var(--muted);
            line-height: 1.6;
        }

        .auth-overlay {
            position: fixed;
            inset: 0;
            z-index: 9999;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 20px;
            background: rgba(2, 6, 23, 0.78);
            backdrop-filter: blur(16px);
        }

        .auth-prompt {
            width: min(440px, 96%);
            border-radius: 28px;
            padding: 30px;
            text-align: center;
        }

        .promo-text {
            color: var(--muted);
            line-height: 1.6;
            font-size: 0.9rem;
        }

        .floating-success {
            display: none;
            margin-top: 16px;
            padding: 15px;
            border-radius: 18px;
            background: rgba(34,197,94,0.10);
            border: 1px solid rgba(34,197,94,0.30);
        }

        .footer {
            padding: 30px 0 50px;
            color: var(--muted);
            text-align: center;
        }

        @media (max-width: 1050px) {
            .hero, .dashboard-grid {
                grid-template-columns: 1fr;
            }

            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .plan-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .feature-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .nav-links {
                display: none;
            }

            .mobile-menu-btn {
                display: inline-flex;
            }
        }

        @media (max-width: 640px) {
            .top-nav {
                padding: 12px 4%;
            }

            .brand span {
                display: none;
            }

            .slot-pill {
                display: none;
            }

            .hero {
                padding-top: 46px;
            }

            .hero-actions, .search-wrap {
                grid-template-columns: 1fr;
                display: grid;
            }

            .stats-grid, .plan-grid, .feature-grid {
                grid-template-columns: 1fr;
            }

            .env-row {
                grid-template-columns: 1fr;
            }

            .app-item {
                grid-template-columns: 1fr;
            }

            .card {
                padding: 18px;
            }
        }
    </style>
</head>
<body>

    <div class="auth-overlay" id="auth-gate">
        <div class="auth-prompt glass">
            <div style="text-align: right;">
                <button onclick="closeAuth()" class="small-btn"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="brand-icon" style="margin: 0 auto 18px;">
                <i class="fa-solid fa-bolt-lightning"></i>
            </div>
            <h2 style="margin: 0;">Access Vinnie Host</h2>
            <p class="promo-text">
                Sign in to deploy backends, manage environment variables, view logs, and get live hosting URLs.
            </p>

            <a href="/auth/github" class="btn btn-primary" style="width:100%; margin-top: 16px;">
                <i class="fa-brands fa-github"></i> Continue with GitHub
            </a>
            <a href="/auth/google" class="btn btn-secondary" style="width:100%; margin-top: 10px;">
                <i class="fa-brands fa-google"></i> Continue with Google
            </a>

            <p style="font-size: 0.75rem; color: #64748b; margin-top: 15px;">Protected OAuth2 login</p>
        </div>
    </div>

    <nav class="top-nav">
        <a href="#home" class="brand">
            <div class="brand-icon"><i class="fa-solid fa-cloud-bolt"></i></div>
            <span>Vinnie Host</span>
        </a>

        <div class="nav-links">
            <a href="#home">Home</a>
            <a href="#deploy">Deploy</a>
            <a href="#apps">Apps</a>
            <a href="#logs">Logs</a>
            <a href="#plans">Plans</a>
            <a href="#features">Features</a>
            <a href="#env">Env Vars</a>
            <a href="#official">Comrades MD</a>
            <a href="#status">Status</a>
            <a href="#support">Support</a>
        </div>

        <div class="nav-right">
            <span class="slot-pill">Global Units: <%= totalDeployed %>/100</span>
            <% if (user) { %>
                <img src="<%= user.avatar %>" class="avatar">
                <a href="/logout" class="small-btn" title="Logout"><i class="fa-solid fa-right-from-bracket"></i></a>
            <% } else { %>
                <button onclick="triggerAuth()" class="btn btn-primary">
                    <i class="fa-solid fa-user-lock"></i> Sign In
                </button>
            <% } %>
            <button class="mobile-menu-btn" onclick="toggleMobileMenu()">
                <i class="fa-solid fa-bars"></i>
            </button>
        </div>
    </nav>

    <div class="mobile-menu" id="mobile-menu">
        <a href="#home">Home</a>
        <a href="#deploy">Deploy</a>
        <a href="#apps">Apps</a>
        <a href="#logs">Logs</a>
        <a href="#plans">Plans</a>
        <a href="#features">Features</a>
        <a href="#env">Env Vars</a>
        <a href="#official">Comrades MD</a>
        <a href="#status">Status</a>
        <a href="#support">Support</a>
    </div>

    <main class="container">
        <section class="hero" id="home">
            <div>
                <span class="badge"><i class="fa-solid fa-wand-magic-sparkles"></i> Modern backend hosting for everyone</span>
                <h1><span class="gradient-text">Deploy bots, APIs & backends fast.</span></h1>
                <p>
                    Welcome <b><%= user ? user.displayName : 'Guest' %></b>. Deploy GitHub backends, scan repositories,
                    set environment variables manually, monitor build logs, and share clean app URLs.
                </p>
                <div class="hero-actions">
                    <button onclick="checkAndAction(() => document.getElementById('deploy').scrollIntoView())" class="btn btn-primary">
                        <i class="fa-solid fa-rocket"></i> Start Deploying
                    </button>
                    <a href="#plans" class="btn btn-secondary">
                        <i class="fa-solid fa-crown"></i> View Plans
                    </a>
                </div>
            </div>

            <div class="hero-panel glass">
                <div class="hero-panel-inner">
                    <div class="mini-terminal">
                        <div class="terminal-top">
                            <span class="dot red"></span>
                            <span class="dot yellow"></span>
                            <span class="dot green"></span>
                        </div>
                        <div class="terminal-code">
                            $ vinnie deploy --repo github.com/user/backend<br>
                            scanning app.json...<br>
                            env builder ready...<br>
                            creating heroku unit...<br>
                            build logs attached...<br>
                            live at https://unit.gathuo.app
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="stats-grid" id="status">
            <div class="stat-card glass">
                <h3><%= totalDeployed %></h3>
                <p>Total active global units</p>
            </div>
            <div class="stat-card glass">
                <h3><%= user ? (user.plan || 'free') : 'guest' %></h3>
                <p>Current user plan</p>
            </div>
            <div class="stat-card glass">
                <h3><%= user && user.deployedApps ? user.deployedApps.length : 0 %></h3>
                <p>Your deployed apps</p>
            </div>
            <div class="stat-card glass">
                <h3>24/7</h3>
                <p>Cloud deployment access</p>
            </div>
        </section>

        <section class="section" id="deploy">
            <div class="section-title">
                <div>
                    <h2>Deploy Center</h2>
                    <p>Paste any public GitHub repository, scan it, add env variables, then deploy.</p>
                </div>
            </div>

            <div class="dashboard-grid">
                <div class="card glass">
                    <h3><i class="fa-solid fa-magnifying-glass"></i> Smart Repository Scanner</h3>
                    <p class="promo-text">
                        If your repo has <b>app.json</b>, variables are loaded automatically. If not, you can add variables manually.
                    </p>

                    <div class="input-group">
                        <label>GitHub Repository URL</label>
                        <div class="search-wrap">
                            <input type="text" id="repoUrl" placeholder="https://github.com/user/repo" value="">
                            <button class="btn btn-primary" id="scan-btn" onclick="checkAndAction(scanBlueprint)">
                                <i class="fa-solid fa-radar"></i> Scan
                            </button>
                        </div>
                    </div>

                    <div id="dynamic-area" class="dynamic-area">
                        <div class="name-gen">
                            <div>
                                <label style="margin-bottom:4px;">Generated App Identity</label>
                                <div class="identity" id="display-app-name"></div>
                            </div>
                            <button class="small-btn" onclick="rotateName()" title="Rotate Identity">
                                <i class="fa-solid fa-rotate"></i>
                            </button>
                        </div>

                        <div class="toggle-box">
                            <span><i class="fa-solid fa-file-code"></i> Force Procfile Startup</span>
                            <input type="checkbox" id="procfile-toggle" checked>
                        </div>

                        <div id="dynamic-inputs" style="max-height: 310px; overflow-y: auto; margin-top: 15px; padding-right: 5px;"></div>

                        <button class="btn btn-secondary" style="width:100%; margin-top:12px;" onclick="addEnvRow()">
                            <i class="fa-solid fa-plus"></i> Add Env Variable
                        </button>

                        <button class="btn btn-success" id="launch-btn" style="width:100%; margin-top:12px;" disabled>
                            <i class="fa-solid fa-bolt"></i> Deploy Now
                        </button>

                        <div id="deploy-success" class="floating-success">
                            <b><i class="fa-solid fa-circle-check"></i> Deployment Started</b>
                            <p style="margin-bottom: 8px;">Your app is being built. Use the logs panel to watch progress.</p>
                            <a id="live-url" class="app-url" target="_blank"></a>
                            <button class="small-btn" style="margin-top:10px;" onclick="copyLiveUrl()">
                                <i class="fa-solid fa-copy"></i> Copy URL
                            </button>
                        </div>
                    </div>
                </div>

                <div class="card glass" id="official">
                    <h3><i class="fa-solid fa-star"></i> Official COMRADES-MD-BOT</h3>
                    <p class="promo-text">
                        Your plans reserve one slot for the official bot repo:
                        <br><b>Vinny256/COMRADES-MD-BOT</b>
                    </p>

                    <button class="btn btn-primary" style="width:100%; margin-top: 12px;" onclick="checkAndAction(quickDeployOfficial)">
                        <i class="fa-solid fa-cloud-arrow-up"></i> Quick Deploy Official Bot
                    </button>

                    <hr style="border:0; border-top:1px solid var(--border); margin:22px 0;">

                    <h3><i class="fa-solid fa-server"></i> Current Unit</h3>
                    <% if(user && user.hasDeployed) { %>
                        <div class="status"><span class="pulse"></span> ONLINE</div>
                        <p style="font-size: 0.9rem;"><strong>Latest ID:</strong> <%= user.activeUnit %></p>
                        <p class="app-url">https://<%= user.activeUnit %>.gathuo.app</p>
                        <div style="display:grid; gap:10px;">
                            <button class="btn btn-secondary" onclick="openApp('<%= user.activeUnit %>')">
                                <i class="fa-solid fa-arrow-up-right-from-square"></i> Open Live App
                            </button>
                            <button class="btn btn-secondary" onclick="copyText('https://<%= user.activeUnit %>.gathuo.app')">
                                <i class="fa-solid fa-copy"></i> Copy URL
                            </button>
                            <button class="btn btn-secondary" onclick="loadConfig('<%= user.activeUnit %>')">
                                <i class="fa-solid fa-gear"></i> Edit Env Vars
                            </button>
                            <button class="btn btn-danger" onclick="terminateUnit('<%= user.activeUnit %>')">
                                <i class="fa-solid fa-circle-xmark"></i> Terminate Latest Unit
                            </button>
                        </div>
                    <% } else { %>
                        <p style="color: var(--muted);">No active deployment yet.</p>
                    <% } %>
                </div>
            </div>
        </section>

        <section class="section" id="apps">
            <div class="section-title">
                <div>
                    <h2>Your Apps</h2>
                    <p>Manage deployed units, copy live URLs, edit configs, or terminate apps.</p>
                </div>
            </div>

            <div class="card glass">
                <% if(user && user.deployedApps && user.deployedApps.length) { %>
                    <div class="app-list">
                        <% user.deployedApps.forEach(function(app) { %>
                            <div class="app-item">
                                <div>
                                    <div class="app-name"><i class="fa-solid fa-cube"></i> <%= app.appName %></div>
                                    <div class="app-url">https://<%= app.appName %>.gathuo.app</div>
                                    <p class="promo-text" style="margin:6px 0 0;">Repo: <%= app.repoUrl %></p>
                                </div>
                                <div style="display:flex; gap:8px; flex-wrap:wrap;">
                                    <button class="small-btn" onclick="openApp('<%= app.appName %>')"><i class="fa-solid fa-up-right-from-square"></i></button>
                                    <button class="small-btn" onclick="copyText('https://<%= app.appName %>.gathuo.app')"><i class="fa-solid fa-copy"></i></button>
                                    <button class="small-btn" onclick="loadConfig('<%= app.appName %>')"><i class="fa-solid fa-gear"></i></button>
                                    <button class="small-btn" onclick="terminateUnit('<%= app.appName %>')" style="color:#fecaca;"><i class="fa-solid fa-trash"></i></button>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <p style="color: var(--muted);">No apps deployed yet. Start by scanning a repo above.</p>
                <% } %>
            </div>
        </section>

        <section class="section" id="env">
            <div class="section-title">
                <div>
                    <h2>Environment Variable Editor</h2>
                    <p>Edit config vars after deployment without redeploying manually from Heroku.</p>
                </div>
            </div>

            <div class="card glass">
                <div class="input-group">
                    <label>Selected App</label>
                    <input type="text" id="config-app-name" placeholder="Click Edit Env Vars on an app" readonly>
                </div>

                <div id="config-editor" style="margin-top:15px;"></div>

                <button class="btn btn-secondary" style="margin-top:12px;" onclick="addConfigRow()">
                    <i class="fa-solid fa-plus"></i> Add Config Variable
                </button>
                <button class="btn btn-primary" style="margin-top:12px;" onclick="saveConfig()">
                    <i class="fa-solid fa-floppy-disk"></i> Save Config Vars
                </button>
            </div>
        </section>

        <section class="section" id="logs">
            <div class="section-title">
                <div>
                    <h2>Build Logs</h2>
                    <p>Watch deployment output. Logs refresh automatically for the latest active unit.</p>
                </div>
                <button class="btn btn-secondary" onclick="downloadLogs()">
                    <i class="fa-solid fa-download"></i> Save Logs
                </button>
            </div>

            <div class="terminal-wrapper">
                <div class="terminal" id="log-stream">
<% if(user && user.hasDeployed) { %>Initializing log stream for <%= user.activeUnit %>...<% } else { %>Deploy an app first to see logs here.<% } %>
                </div>
            </div>
        </section>

        <section class="section" id="plans">
            <div class="section-title">
                <div>
                    <h2>Plans</h2>
                    <p>Simple pricing for backends, bots, and APIs. Each non-gold plan reserves one official bot slot.</p>
                </div>
            </div>

            <div class="plan-grid">
                <div class="plan-card glass">
                    <h3>Free</h3>
                    <div class="plan-price">KSh 0</div>
                    <ul>
                        <li>2 backends</li>
                        <li>1 official bot slot</li>
                        <li>Basic logs</li>
                    </ul>
                </div>

                <div class="plan-card glass">
                    <h3>Startup</h3>
                    <div class="plan-price">KSh 20</div>
                    <ul>
                        <li>5 backends</li>
                        <li>1 official bot slot</li>
                        <li>Config editor</li>
                    </ul>
                </div>

                <div class="plan-card glass featured">
                    <h3>Silver</h3>
                    <div class="plan-price">KSh 50</div>
                    <ul>
                        <li>10 backends</li>
                        <li>1 official bot slot</li>
                        <li>Better scaling</li>
                    </ul>
                </div>

                <div class="plan-card glass">
                    <h3>Platinum</h3>
                    <div class="plan-price">KSh 100</div>
                    <ul>
                        <li>50 backends</li>
                        <li>1 official bot slot</li>
                        <li>Advanced usage</li>
                    </ul>
                </div>

                <div class="plan-card glass">
                    <h3>Gold</h3>
                    <div class="plan-price">KSh 250</div>
                    <ul>
                        <li>Unlimited hosting</li>
                        <li>No reserved slot limit</li>
                        <li>Best for power users</li>
                    </ul>
                </div>
            </div>
        </section>

        <section class="section" id="features">
            <div class="section-title">
                <div>
                    <h2>Features</h2>
                    <p>Built to feel like a mini Railway/Heroku-style hosting control panel.</p>
                </div>
            </div>

            <div class="feature-grid">
                <div class="feature-card glass"><i class="fa-solid fa-code-branch"></i><h3>Repo Scanner</h3><p>Detect app.json or Procfile and prepare variables automatically.</p></div>
                <div class="feature-card glass"><i class="fa-solid fa-key"></i><h3>Env Builder</h3><p>Add manual variables even when the repo has no app.json.</p></div>
                <div class="feature-card glass"><i class="fa-solid fa-terminal"></i><h3>Live Logs</h3><p>Show users deployment and runtime output in a clean terminal.</p></div>
                <div class="feature-card glass"><i class="fa-solid fa-link"></i><h3>Clean URLs</h3><p>Show users their app as a gathuo.app style URL.</p></div>
                <div class="feature-card glass"><i class="fa-solid fa-mobile-screen"></i><h3>Responsive UI</h3><p>Works well on phones, tablets, and desktops.</p></div>
                <div class="feature-card glass"><i class="fa-solid fa-crown"></i><h3>Plans</h3><p>Free and paid hosting tiers with deployment limits.</p></div>
            </div>
        </section>

        <section class="section" id="support">
            <div class="card glass">
                <h2 style="margin-top:0;">Need help?</h2>
                <p class="promo-text">If deployment fails, check logs, confirm repo is public, and make sure required env variables are filled correctly.</p>
                <button class="btn btn-primary" onclick="document.getElementById('logs').scrollIntoView()">
                    <i class="fa-solid fa-terminal"></i> View Logs
                </button>
            </div>
        </section>

        <footer class="footer">
            Vinnie Host © <%= new Date().getFullYear() %> — Cloud deployment made simple.
        </footer>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <script>
        const isLoggedIn = <%= user ? 'true' : 'false' %>;
        let currentGeneratedName = `vinnie-${Math.random().toString(36).substring(2, 7)}`;
        let latestLiveUrl = "";

        function triggerAuth() {
            document.getElementById('auth-gate').style.display = 'flex';
        }

        function closeAuth() {
            document.getElementById('auth-gate').style.display = 'none';
        }

        function toggleMobileMenu() {
            const menu = document.getElementById('mobile-menu');
            menu.style.display = menu.style.display === 'block' ? 'none' : 'block';
        }

        function checkAndAction(cb) {
            isLoggedIn ? cb() : triggerAuth();
        }

        function showToast(text, color = "linear-gradient(135deg, #7c3aed, #06b6d4)") {
            Toastify({
                text,
                duration: 3200,
                gravity: "top",
                position: "right",
                style: {
                    background: color,
                    borderRadius: "14px",
                    boxShadow: "0 15px 45px rgba(0,0,0,0.35)"
                }
            }).showToast();
        }

        function rotateName() {
            currentGeneratedName = `vinnie-${Math.random().toString(36).substring(2, 7)}`;
            const display = document.getElementById('display-app-name');
            if (display) display.innerText = currentGeneratedName;
            showToast("Identity rotated");
        }

        async function quickDeployOfficial() {
            const repo = document.getElementById('repoUrl');
            if (!repo) return;
            repo.value = "https://github.com/Vinny256/COMRADES-MD-BOT";
            document.getElementById('deploy').scrollIntoView();
            scanBlueprint();
        }

        async function scanBlueprint() {
            const repoUrl = document.getElementById('repoUrl').value.trim();
            if (!repoUrl) return showToast("Enter a repository URL", "#ef4444");

            const scanBtn = document.getElementById('scan-btn');
            scanBtn.disabled = true;
            scanBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Scanning...';

            try {
                const res = await fetch('/deploy/scan', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ repoUrl })
                });

                const data = await res.json();

                if (data.success) {
                    const inputContainer = document.getElementById('dynamic-inputs');
                    inputContainer.innerHTML = '';

                    rotateName();

                    if (!data.requirements || data.requirements.length === 0) {
                        inputContainer.innerHTML = '<p class="promo-text" style="color:#fbbf24;">No app.json variables found. Add your env variables manually below.</p>';
                        addEnvRow();
                    } else {
                        data.requirements.forEach(item => {
                            if (item.key !== 'HEROKU_API_KEY') createVarInput(inputContainer, item.key, item.value, item.description);
                        });
                    }

                    document.getElementById('dynamic-area').style.display = 'block';
                    document.getElementById('launch-btn').onclick = () => launchToGrid(data.repo);
                    validateForm();
                    showToast("Repository scan complete", "#22c55e");
                } else {
                    document.getElementById('dynamic-area').style.display = 'block';
                    document.getElementById('dynamic-inputs').innerHTML = '<p class="promo-text" style="color:#fbbf24;">No app.json or Procfile found. You can still add env variables manually.</p>';
                    document.getElementById('launch-btn').onclick = () => launchToGrid(repoUrl);
                    rotateName();
                    validateForm();
                    showToast(data.message || "Manual mode ready", "#f59e0b");
                }
            } catch (e) {
                showToast("Scan failed", "#ef4444");
            } finally {
                scanBtn.disabled = false;
                scanBtn.innerHTML = '<i class="fa-solid fa-radar"></i> Scan';
            }
        }

        function createVarInput(container, key, val, desc) {
            const div = document.createElement('div');
            div.className = 'env-row';
            div.innerHTML = `
                <input type="text" class="env-key-input" value="${escapeHtml(key || '')}" placeholder="KEY">
                <input type="text" class="env-var-input" value="${escapeHtml(val || '')}" placeholder="${escapeHtml(desc || 'VALUE')}">
                <button class="small-btn" onclick="this.parentElement.remove(); validateForm();"><i class="fa-solid fa-trash"></i></button>
            `;
            container.appendChild(div);
            div.querySelectorAll('input').forEach(input => input.addEventListener('input', validateForm));
        }

        function addEnvRow() {
            const container = document.getElementById('dynamic-inputs');
            createVarInput(container, "", "", "");
            validateForm();
        }

        function validateForm() {
            const launchBtn = document.getElementById('launch-btn');
            if (!launchBtn) return;

            const rows = document.querySelectorAll('#dynamic-inputs .env-row');
            let valid = true;

            rows.forEach(row => {
                const key = row.querySelector('.env-key-input')?.value.trim();
                const value = row.querySelector('.env-var-input')?.value.trim();
                if (!key || !value) valid = false;
            });

            launchBtn.disabled = !valid;
            launchBtn.style.opacity = valid ? "1" : "0.55";
        }

        async function launchToGrid(repoUrl) {
            const configVars = { "APP_NAME": currentGeneratedName };

            document.querySelectorAll('#dynamic-inputs .env-row').forEach(row => {
                const key = row.querySelector('.env-key-input')?.value.trim();
                const value = row.querySelector('.env-var-input')?.value.trim();
                if (key) configVars[key] = value;
            });

            if (document.getElementById('procfile-toggle').checked) {
                configVars["USE_PROCFILE"] = "true";
            }

            const launchBtn = document.getElementById('launch-btn');
            launchBtn.disabled = true;
            launchBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Deploying...';

            try {
                const res = await fetch('/deploy/launch', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ repoUrl, configVars })
                });

                const data = await res.json();

                if (data.success) {
                    latestLiveUrl = data.customUrl || `https://${data.appName}.gathuo.app`;
                    document.getElementById('deploy-success').style.display = 'block';
                    document.getElementById('live-url').innerText = latestLiveUrl;
                    document.getElementById('live-url').href = latestLiveUrl;
                    showToast("Deployment started successfully", "#22c55e");

                    setTimeout(() => {
                        window.location.reload();
                    }, 2500);
                } else {
                    showToast(data.message || "Deployment failed", "#ef4444");
                }
            } catch (e) {
                showToast("Deployment request failed", "#ef4444");
            } finally {
                launchBtn.disabled = false;
                launchBtn.innerHTML = '<i class="fa-solid fa-bolt"></i> Deploy Now';
            }
        }

        async function terminateUnit(appName) {
            if (!confirm("Terminate this app?")) return;

            const res = await fetch('/deploy/terminate', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ appName })
            });

            const data = await res.json();

            if (data.success) {
                showToast("App terminated", "#22c55e");
                window.location.reload();
            } else {
                showToast(data.message || "Termination failed", "#ef4444");
            }
        }

        function openApp(appName) {
            window.open(`https://${appName}.gathuo.app`, '_blank');
        }

        function copyText(text) {
            navigator.clipboard.writeText(text);
            showToast("Copied to clipboard", "#22c55e");
        }

        function copyLiveUrl() {
            if (!latestLiveUrl) return;
            copyText(latestLiveUrl);
        }

        async function loadConfig(appName) {
            document.getElementById('env').scrollIntoView();
            document.getElementById('config-app-name').value = appName;
            const editor = document.getElementById('config-editor');
            editor.innerHTML = '<p class="promo-text">Loading config variables...</p>';

            try {
                const res = await fetch(`/deploy/config/${appName}`);
                const data = await res.json();

                editor.innerHTML = "";

                const config = data.config || {};

                Object.keys(config).forEach(key => {
                    addConfigRow(key, config[key]);
                });

                if (Object.keys(config).length === 0) {
                    editor.innerHTML = '<p class="promo-text">No config vars found. Add new ones below.</p>';
                }

                showToast("Config loaded", "#22c55e");
            } catch (e) {
                editor.innerHTML = '<p class="promo-text" style="color:#fecaca;">Failed to load config.</p>';
            }
        }

        function addConfigRow(key = "", value = "") {
            const editor = document.getElementById('config-editor');
            const row = document.createElement('div');
            row.className = 'env-row';
            row.innerHTML = `
                <input type="text" class="config-key" value="${escapeHtml(key)}" placeholder="KEY">
                <input type="text" class="config-value" value="${escapeHtml(value)}" placeholder="VALUE">
                <button class="small-btn" onclick="this.parentElement.remove();"><i class="fa-solid fa-trash"></i></button>
            `;
            editor.appendChild(row);
        }

        async function saveConfig() {
            const appName = document.getElementById('config-app-name').value.trim();
            if (!appName) return showToast("Select an app first", "#ef4444");

            const body = {};
            document.querySelectorAll('#config-editor .env-row').forEach(row => {
                const key = row.querySelector('.config-key')?.value.trim();
                const value = row.querySelector('.config-value')?.value.trim();
                if (key) body[key] = value;
            });

            const res = await fetch(`/deploy/config/${appName}`, {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify(body)
            });

            const data = await res.json();

            if (data.updated || data.success) {
                showToast("Config updated", "#22c55e");
            } else {
                showToast("Config update failed", "#ef4444");
            }
        }

        function downloadLogs() {
            const logElement = document.getElementById('log-stream');
            if (!logElement) return;

            const blob = new Blob([logElement.innerText], { type: 'text/plain' });
            const elem = window.document.createElement('a');
            elem.href = window.URL.createObjectURL(blob);
            elem.download = 'vinnie-host-logs.txt';
            document.body.appendChild(elem);
            elem.click();
            document.body.removeChild(elem);
        }

        function escapeHtml(str) {
            return String(str)
                .replaceAll('&', '&amp;')
                .replaceAll('<', '&lt;')
                .replaceAll('>', '&gt;')
                .replaceAll('"', '&quot;')
                .replaceAll("'", '&#039;');
        }

        <% if(user && user.hasDeployed) { %>
            let lastLogs = "";
            setInterval(() => {
                fetch('/deploy/logs/<%= user.activeUnit %>')
                    .then(res => res.json())
                    .then(data => {
                        const lb = document.getElementById('log-stream');
                        if (lb && data.logs && data.logs !== lastLogs) {
                            lastLogs = data.logs;
                            lb.innerText = data.logs;
                            lb.scrollTop = lb.scrollHeight;
                        }
                    })
                    .catch(() => {});
            }, 5000);
        <% } %>
    </script>
</body>
</html>
